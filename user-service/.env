# PostgreSQL Configuration
DATABASE_URL=postgresql://postgres:postgres@postgres-user:5432/user_db

# API Configuration
API_PREFIX=/api/v1
DEBUG=False
PORT=8003

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-key-here-change-it-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Security
SECURITY_PASSWORD_SALT=your-password-salt-change-it
SECURITY_PASSWORD_HASH=bcrypt

# Email Configuration (for sending verification emails, password resets)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your-email@example.com
MAIL_PASSWORD=your-email-password
MAIL_FROM=your-email@example.com
MAIL_TLS=True
MAIL_SSL=False
MAIL_FROM_NAME=E-Commerce User Service

# URL Configuration
VERIFY_EMAIL_URL=http://localhost:8003/api/v1/auth/verify-email
RESET_PASSWORD_URL=http://localhost:8003/api/v1/auth/reset-password

# Feature Flags
ENABLE_EMAIL_VERIFICATION=false  # Set to true to require email verification